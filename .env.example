# 애플리케이션 설정
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# Redis
REDIS_URL=redis://localhost:6379

# Vellum (Ray GPU 서빙 플랫폼용)
VELLUM_API_KEY=your-vellum-api-key-here

# AWS (Terraform/ECR 배포용)
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=123456789012
ECR_REPOSITORY=devops-starter-api

# GitHub MCP 서버용 Personal Access Token
# 저장 위치: Windows 사용자 환경변수 (제어판 > 시스템 > 고급 시스템 설정 > 환경 변수)
# 발급: GitHub > Settings > Developer settings > Personal access tokens > Fine-grained tokens
# 필요 권한: Contents(Read), Issues(Read/Write), Pull requests(Read/Write), Metadata(Read), Actions(Read)
# 등록 방법: [System.Environment]::SetEnvironmentVariable("GITHUB_PERSONAL_ACCESS_TOKEN", "ghp_xxx", "User")

#  ~/.bashrc → GITHUB_PERSONAL_ACCESS_TOKEN 등록
#    → Claude Code 실행 (환경변수 상속)                                                                                                                                                                 → MCP 서버(npx) 실행 (환경변수 자동 상속)
#    → 별도로 env 블록 없어도 토큰 인식

GITHUB_PERSONAL_ACCESS_TOKEN=your-github-personal-access-token-here
