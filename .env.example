# 애플리케이션 설정
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# Redis
REDIS_URL=redis://localhost:6379

# Vellum (Ray GPU 서빙 플랫폼용)
VELLUM_API_KEY=your-vellum-api-key-here

# AWS (Terraform/ECR 배포용)
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=123456789012
ECR_REPOSITORY=devops-starter-api
