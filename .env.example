# 애플리케이션 설정
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# Redis
REDIS_URL=redis://localhost:6379

# Vellum (Ray GPU 서빙 플랫폼용)
VELLUM_API_KEY=your-vellum-api-key-here

# AWS (Terraform/ECR 배포용)
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=123456789012
ECR_REPOSITORY=devops-starter-api

# GitHub MCP 서버용 Personal Access Token
# 발급: GitHub > Settings > Developer settings > Personal access tokens > Fine-grained tokens
# 필요 권한: Contents(Read), Issues(Read/Write), Pull requests(Read/Write), Metadata(Read), Actions(Read)
#
# [권장] Windows 사용자 환경변수로 등록 (PowerShell에서 1회 실행)
#   [System.Environment]::SetEnvironmentVariable("GITHUB_PERSONAL_ACCESS_TOKEN", "ghp_xxx", "User")
#
#   → cmd.exe / PowerShell / Git Bash / Claude Code 데스크탑 앱 모두에서 자동 상속됨
#   → .mcp.json에 토큰을 직접 쓸 필요 없음
#
# [주의] .bashrc에 export로 등록하는 방식은 Git Bash에서만 동작하며,
#        Claude Code를 항상 Git Bash에서 실행하는 경우에만 유효함.
#        두 곳에 모두 등록하면 Git Bash 실행 시 .bashrc 값이 Windows 환경변수를 덮어씀.

GITHUB_PERSONAL_ACCESS_TOKEN=your-github-personal-access-token-here
